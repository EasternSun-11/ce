# 复制为 signing.env 后填入 simpleDemo/build.gradle（勿提交 signing.env）
STORE_FILE=../../keystore/ui-app-release.keystore
KEY_ALIAS=uiapp
STORE_PASSWORD=uiapp123456
KEY_PASSWORD=uiapp123456

# DCloud 离线 AppKey（开发者中心申请，需与下方 SHA1、包名一致）
DCLOUD_APPKEY=

# manifest 中的包名
APPLICATION_ID=asia.cancan.uiapp

# 申请离线 Key 时填写的 SHA1（setup-keystore.ps1 输出）
# SHA1: 35:BD:CA:0B:EC:1C:DA:97:CB:17:8D:AD:C9:E1:D5:3C:AD:72:30:2A
# SHA256: F2:FE:49:33:20:DB:83:FA:13:8D:39:07:F5:D8:69:C4:B9:72:97:92:2A:B9:C9:40:56:C7:1A:0B:49:20:44:D0
